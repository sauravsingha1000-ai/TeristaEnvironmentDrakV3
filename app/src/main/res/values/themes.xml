<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ MAIN APP THEME - Dark -->
    <style name="Theme.TeristaEnvironment" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/bg_main</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorSecondaryVariant">@color/accent_purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_nav</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>

        <!-- Switch colors -->
        <item name="colorControlActivated">@color/accent_purple</item>
        <item name="switchStyle">@style/SwitchStyle</item>
    </style>

    <!-- ✅ SWITCH STYLE -->
    <style name="SwitchStyle" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/white</item>
        <item name="trackTint">@color/switch_track_tint</item>
    </style>

    <!-- ✅ TOOLBAR STYLE -->
    <style name="ToolBarColorStyle" parent="ThemeOverlay.MaterialComponents.ActionBar">
        <item name="actionMenuTextColor">@color/primary_text</item>
        <item name="colorControlNormal">@color/primary_text</item>
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <!-- ✅ BOTTOM NAV STYLE -->
    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_nav</item>
        <item name="itemIconTint">@color/nav_icon_color</item>
        <item name="itemTextColor">@color/nav_icon_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

</resources>
