<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:paddingBottom="80dp">

    <!-- Icon container -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_icon_btn"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_empty_box"
            android:contentDescription="No apps" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Apps Installed"
        android:textColor="@color/primary_text"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="Install APKs to run them in a secure virtual environment. Supports Android 7 through 15."
        android:textColor="@color/secondary_text"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:id="@+id/btn_install_first"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_btn_purple"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_add_white"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Install First App"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>